---
interface Props {
  title?: string;
  subtitle?:string;
  description?:string;
  pill?:string;
}

const { title = "United Media Services | Oman's Largest Integrated Media House",pill} = Astro.props;
import Navigation from '../components/Navigation.astro';
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />

    <title>{ title }</title>
  </head>
  <body class="bg-brand-background text-brand-secondary px-6 py-4 lg:px-30 lg:py-8">
    <Navigation pill=`${ pill }`/>
    
       <slot />

      

       <script>
      import Lenis from 'lenis';

      function initSmoothScroll() {
       
        const lenis = new Lenis({
          duration: 1.2,       
          easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)), 
          orientation: 'vertical',
          gestureOrientation: 'vertical',
          smoothWheel: true,   
          wheelMultiplier: 1,  
          touchMultiplier: 2,
          infinite: false,
        });

        
        function raf(time: number) {
          lenis.raf(time);
          requestAnimationFrame(raf);
        }

        requestAnimationFrame(raf);
      }

      
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSmoothScroll);
      } else {
        initSmoothScroll();
      }
      document.addEventListener('astro:after-swap', initSmoothScroll);
    </script>

    <script>
      import Lenis from 'lenis';

      function initScrollAnimations() {
        // 1. Target all elements marked for reveal automation
        const revealElements = document.querySelectorAll('.reveal-on-scroll');
        
        // 2. Configure the hardware sensor observer
        const observerOptions = {
          root: null,          // Tracks relative to the device viewport window
          rootMargin: '0px 0px -10% 0px', // Triggers slightly before the element fully clears the bottom edge
          threshold: 0.1       // Fires the instant 10% of the target element is visible
        };

        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach(entry => {
            // When the content block enters the viewport...
            if (entry.isIntersecting) {
              // Inject the visibility class to trigger the smooth CSS transform hardware transition
              entry.target.classList.add('is-visible');
              
              // Stop tracking this element once it has been revealed so it doesn't fire repeatedly
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        // 3. Attach the observer tracker loop to all targeted nodes
        revealElements.forEach(element => observer.observe(element));
      }

      // Bind execution to standard DOM load lifecycle states and Astro page swaps
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          // (Your Lenis init logic runs here too)
          initScrollAnimations();
        });
      } else {
        initScrollAnimations();
      }
      document.addEventListener('astro:after-swap', initScrollAnimations);
    </script>

<style is:global>
  body::after {
    content: "";
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: -10; 
    
    background-image: url('/batthern.png');
    background-repeat: repeat;
    opacity: 0.4; 
    
    /* 🎯 ANIMATION TRIGGERS */
    /* 20s = speed (lower means faster). linear = consistent velocity. infinite = loops forever */
    animation: move-bg 20s linear infinite;
    
    /* Tells the GPU to handle this layer for smooth Lenis scrolling performance */
    will-change: background-position; 
  }

  /* 🏎️ THE ANIMATION ENGINE */
  @keyframes move-bg {
    0% {
      /* Starting position */
      background-position: 0px 0px;
    }
    100% {
      /* 🎛️ DIRECTION CONTROLLER:
         - For pure horizontal movement: change to '300px 0px'
         - For diagonal movement (down and right): keep it at '300px 300px'
      */
      background-position: 300px 300px;
    }
  }
</style>

  </body>
</html>