---
interface Props {
  videoMp4: string;
  videoWebm?: string;
}

const { videoMp4, videoWebm } = Astro.props;
---
<div class="p-0 lg:px-0">
<div class="w-full aspect-video md:overflow-hidden bg-brand-primary/5 relative group animate-reveal-up z-1">
  
  <video
    id="ums-showreel"
    class="w-full h-full object-cover pointer-events-auto"
    autoplay
    loop
    muted
    controls
    playsinline
    preload="none"
  >
    {videoWebm && <source src={videoWebm} type="video/webm" />}
    <source src={videoMp4} type="video/mp4" />
    Your browser does not support the video tag.
  </video>

</div>
</div>

<script>
  function initShowreel() {
    const video = document.getElementById('ums-showreel') as HTMLVideoElement | null;

    if (!video) return;

    // LAZY LOAD ASSETS
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          video.preload = 'metadata';
          // 🎯 Force the browser play engine once the container scrolls into view
          video.play().catch(err => console.log("Autoplay interrupted:", err));
          observer.unobserve(video);
        }
      });
    }, { rootMargin: '200px' }); 

    observer.observe(video);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShowreel);
  } else {
    initShowreel();
  }
  document.addEventListener('astro:after-swap', initShowreel);
</script>